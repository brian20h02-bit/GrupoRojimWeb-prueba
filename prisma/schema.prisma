generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPCIONISTA
  VENDEDOR
}

enum StockMovementType {
  ENTRADA
  SALIDA
}

model User {
  id           String          @id @default(uuid())
  name         String
  email        String          @unique
  passwordHash String
  role         Role
  createdAt    DateTime        @default(now())
  movements    StockMovement[]

  @@index([role])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          String          @id @default(uuid())
  name        String
  code        String          @unique
  description String?
  price       Decimal         @db.Decimal(10, 2)
  brand       String
  unitPerBox  Int
  stockMin    Int             @default(0)
  active      Boolean         @default(true)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  movements   StockMovement[]

  @@index([categoryId])
  @@index([active])
  @@index([name])
}

model StockMovement {
  id        String            @id @default(uuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  type      StockMovementType
  quantity  Int
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  reason    String?
  reference String?
  notes     String?
  createdAt DateTime          @default(now())

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
